{
  "name": "next-commerce",
  "version": "1.0.0",
  "description": "A modern full-stack e-commerce platform built with Next.js 14 and Stripe",
  "author": "Alfredo Wiesner <alrod.dev@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.ts",
    "postinstall": "prisma generate || true"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tailwindcss": "3.4.1",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "@stripe/stripe-js": "^2.1.0",
    "stripe": "^14.0.0",
    "next-auth": "^4.24.0",
    "@prisma/client": "^5.7.0",
    "prisma": "^5.7.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0",
    "lucide-react": "^0.294.0",
    "sharp": "^0.33.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "prettier": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  }
}
